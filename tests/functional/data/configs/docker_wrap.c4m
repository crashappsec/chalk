run_sbom_tools = env("DOCKER_SBOM") == "true"
docker.scan_context.run = true
docker.wrap_entrypoint = true
docker.download_arch_binary_urls = [env("CHALK_SERVER") + "/dummy/chalk-{version}-{os}-{architecture}"]
docker.arch_binary_locations_path = env("CHALK_TMP")

docker {
  docker_registry local {
    enabled: env_exists("CHALK_SERVER")
    uri: env("IP") + ":5048"
    login_method: "get"
    docker_login_get {
      uri: env("CHALK_SERVER") + "/registry/auth"
    }
    docker_push mirror {
      repository: "mirror"
      tags: ["mirror:{chalk_rand}"]
    }
  }
}
