docker {
  docker_registry local {
    enabled: env_exists("CHALK_SERVER")
    uri: env("IP") + ":5048"
    login_method: "get"
    docker_login_get {
      uri: env("CHALK_SERVER") + "/registry/auth"
    }
    docker_push context {
      repository: "context"
      tags: ["context:{chalk_rand}"]
      upload_context: true
      upload_context_strategy: env("CONTEXT_STRATEGY")
    }
  }
}
